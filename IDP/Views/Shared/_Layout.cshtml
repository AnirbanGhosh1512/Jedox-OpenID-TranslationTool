<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] – Translation Tool IdP</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
        }
        .card {
            background: #fff; border-radius: 16px;
            padding: 44px 40px; max-width: 420px; width: 100%;
            box-shadow: 0 24px 64px rgba(0,0,0,0.22);
        }
        .card-header { text-align: center; margin-bottom: 28px; }
        .card-header h2 { font-size: 1.7rem; color: #1a1a2e; margin-bottom: 6px; }
        .card-header p  { color: #888; font-size: 0.9rem; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 500;
                            color: #444; margin-bottom: 6px; }
        .form-control {
            width: 100%; padding: 11px 14px;
            border: 2px solid #e5e7eb; border-radius: 8px;
            font-size: 0.95rem; transition: border-color .2s; outline: none;
        }
        .form-control:focus { border-color: #667eea; }
        .btn-submit {
            width: 100%; padding: 13px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff; border: none; border-radius: 8px;
            font-size: 1rem; font-weight: 600; cursor: pointer;
            margin-top: 6px; transition: opacity .2s;
        }
        .btn-submit:hover { opacity: .88; }
        .alert-error {
            background: #fee2e2; color: #dc2626;
            padding: 10px 14px; border-radius: 8px;
            margin-bottom: 16px; font-size: 0.875rem;
        }
        .hint { text-align: center; margin-top: 18px; font-size: 0.82rem; color: #aaa; }
        .hint strong { color: #667eea; }
        .field-validation-error { color: #dc2626; font-size: 0.78rem; }
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>